;*******************************  IM2BMP.DEF  *******************************
;
;  Modul Definitions File für IM2BMP.EXE
;
;  IM2BMP.DEF, Version 1.10, 1/90
;
;  Das Modul-Definitions File enthält zusätzliche Informationen für den
;  LINKER.
;
;  WINDOWCOMPAT heisst, dass das Programm im einem Textfenster
;               unter dem Presentation Manager laufen kann.

NAME    IM2BMP WINDOWCOMPAT

DESCRIPTION 'Konvertierung im --> bmp'

DATA    MULTIPLE

STACKSIZE   4048
HEAPSIZE    2048

PROTMODE
